generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id              Int     @id @default(autoincrement())
  name            String
  title           String
  summary         String
  email           String
  phone           String
  github          String
  linkedin        String
  profileImageUrl  String?
  careerObjective  String?
  strengths       String[]
  cvOriginalName  String? @map("cv_original_name")
  cvFileName      String? @map("cv_filename")
  cvMime          String? @map("cv_mime")
  cvData          String? @map("cv_data")
  cvSourceHtml    String? @map("cv_source_html")

  @@map("profiles")
}

model Skill {
  id       Int    @id @default(autoincrement())
  category String
  name     String

  @@unique([category, name])
  @@map("skills")
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  techStack   String[]
  githubLink  String?
  liveDemo    String?

  @@map("projects")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model Education {
  id          Int    @id @default(autoincrement())
  institution String
  program     String
  description String
  statusTag   String?
  sortOrder   Int

  @@map("education")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  adminEmail String
  action    String
  method    String
  endpoint  String
  details   String?
  statusCode Int?
  errorMessage String?
  timestamp DateTime @default(now())
  ipAddress String?

  @@map("audit_logs")
  @@index([adminEmail])
  @@index([timestamp])
}

